{
  "name": "fairy",
  "version": "0.1.0",
  "private": true,
  "description": "A local-first AI companion for Windows.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && electron .\"",
    "dev:server": "node server/fairy-local-server.cjs",
    "dev:web": "vite --host 127.0.0.1",
    "shell:web": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-fairy-web-shell.ps1",
    "electron:install": "node scripts/install-electron.cjs",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "start": "electron ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sql.js": "^1.13.0",
    "vite": "^7.3.0",
    "wait-on": "^9.0.3"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
